import axios from "axios";

const BASE_URL = "http://localhost:8080";

export const createAuthorization = (data) => {
    return axios.post(`${BASE_URL}/api/auth/create`, data);
};

export const getAllAuthorizations = () => {
    return axios.get(`${BASE_URL}/api/auth/all`);
};

export const approveAuthorization = (id) => {
    return axios.put(`${BASE_URL}/api/payer/approve/${id}`);
};

export const rejectAuthorization = (id, comment) => {
    return axios.put(`${BASE_URL}/api/payer/reject/${id}`, { comment });
};

export const getDashboard = () => {
    return axios.get(`${BASE_URL}/api/payer/dashboard`);
};

export const getNotifications = (providerId) => {
    return axios.get(`${BASE_URL}/api/notification/${providerId}`);
};

export const getAllNotifications = () => {
    return axios.get(`${BASE_URL}/api/notification/all`);
};

export const getNotificationCount = () => {
    return axios.get(`${BASE_URL}/api/notification/count`);
};

